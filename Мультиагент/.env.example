# ==== Мультиагентный бот — шаблон настроек ====
# Скопируй этот файл в .env и впиши значения. .env в git НЕ попадает.
# Никогда не коммить реальные ключи.

# --- Telegram ---
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# Куда публиковать посты: @имя_канала или числовой ID (-100...)
TELEGRAM_CHANNEL_ID=
# Твой Telegram ID (кому бот шлёт пост на проверку). Узнать: напиши @userinfobot
TELEGRAM_ADMIN_ID=

# --- Модели (переключаются здесь, без правки кода) ---
# Модель для текст-агентов (работает через Claude Code на подписке, API-ключ не нужен)
TEXT_MODEL=sonnet
# Модель для картинок (OpenAI)
IMAGE_MODEL=gpt-image-1

# --- OpenAI (нужен только для картинок) ---
OPENAI_API_KEY=

# --- Расписание ---
# Во сколько бот сам генерит пост (24ч формат ЧЧ:ММ)
POST_TIME=10:00
